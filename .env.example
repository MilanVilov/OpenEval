# Copy this file to .env for local development only.
# Do not commit .env.
# Replace OPENAI_API_KEY, APP_MYSQL_CLIENT_PASS, and MYSQL_ROOT_PASSWORD before starting services.
OPENAI_API_KEY=
APP_MYSQL_CLIENT_DB=openeval
APP_MYSQL_CLIENT_HOST=127.0.0.1
APP_MYSQL_CLIENT_PORT=3306
APP_MYSQL_CLIENT_USER=openeval
APP_MYSQL_CLIENT_PASS=change-me
APP_DB_CONNECTION_POOL=5
APP_BASE_URL=
MYSQL_ROOT_PASSWORD=change-me-root
# Host port for the Compose MySQL service. Use 3307 if local port 3306 is already in use.
MYSQL_PORT=3306
UPLOAD_DIR=data/uploads
DEFAULT_CONCURRENCY=5
HOST=0.0.0.0
PORT=8000
